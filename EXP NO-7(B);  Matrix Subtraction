AIM: 
To write a C program to perform the subtraction of two matrices. 
 
 
ALGORITHM: 
1. Start the program. 
2. Declare variables for two matrices and the difference matrix. 
3. Read the number of rows and columns. 
4. Read elements for the first matrix. 
5. Read elements for the second matrix. 
6. Perform subtraction: 
  ->diff[i][j] = mat1[i][j] - mat2[i][j] 
7. Display the difference matrix. 
8. Stop. 
 
 
PROGRAM: 
#include <stdio.h> 
int main() { 
int mat1[10][10], mat2[10][10], diff[10][10]; 
int r, c, i, j; 
printf("Enter number of rows and columns: "); 
scanf("%d %d", &r, &c); 
printf("Enter elements of first matrix:\n"); 
for (i = 0; i < r; i++) { 
for (j = 0; j < c; j++) { 
scanf("%d", &mat1[i][j]); 
} 
} 
printf("Enter elements of second matrix:\n"); 
for (i = 0; i < r; i++) { 
for (j = 0; j < c; j++) { 
scanf("%d", &mat2[i][j]); 
} 
} 
// Matrix Subtraction 
for (i = 0; i < r; i++) { 
for (j = 0; j < c; j++) { 
diff[i][j] = mat1[i][j] - mat2[i][j]; 
} 
} 
printf("\nDifference of matrices:\n"); 
for (i = 0; i < r; i++) { 
for (j = 0; j < c; j++) { 
printf("%d\t", diff[i][j]); 
} 
printf("\n"); 
} 
return 0; 
} 
 
 
